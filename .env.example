# LLM Provider Configuration
# Options: groq, ollama, watsonx
LLM_PROVIDER=groq

# Groq Configuration (Fast, Free Tier)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama Configuration (Local, Fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# IBM watsonx.ai Configuration (Future)
# Get credentials at: https://cloud.ibm.com/
WATSONX_API_KEY=your_ibm_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-13b-instruct-v2